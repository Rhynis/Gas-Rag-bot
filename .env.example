# ============================================
# Environment
# ============================================
ENVIRONMENT=development
DEBUG=true

# ============================================
# Database (PostgreSQL via Supabase or local)
# ============================================
DATABASE_URL=postgresql+asyncpg://gasbot:gasbot_dev_password@localhost:5432/gasbot_dev

# ============================================
# Supabase (for production)
# ============================================
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# ============================================
# Redis (caching and rate limiting)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# LLM Configuration
# ============================================
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_TIMEOUT=120
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ============================================
# Embeddings
# ============================================
EMBEDDING_MODEL=keepitreal/vietnamese-sbert
EMBEDDING_DIMENSIONS=768

# ============================================
# Observability
# ============================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=

# ============================================
# Security
# ============================================
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_LLM_PER_MINUTE=10

# ============================================
# Frontend Public Variables (NEXT_PUBLIC_*)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_NAME=GasBot Vietnam
